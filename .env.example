# Supabase self-hosted API URL and public anon key.
# Leave both unset to disable cloud sync UI.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional client telemetry endpoint (POST JSON error/warning events).
# VITE_TELEMETRY_URL=https://example.com/telemetry

# Optional Supabase-backed client telemetry. Requires the telemetry_events migration.
# VITE_TELEMETRY_SUPABASE=true
