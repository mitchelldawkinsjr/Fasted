# Supabase self-hosted API URL and public anon key.
# Leave both unset to disable cloud sync UI.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Web Push VAPID public key (generate with: npx web-push generate-vapid-keys --json).
# Pair with VAPID_PRIVATE_KEY on the server for scripts/send-push-reminders.mjs.
# VITE_VAPID_PUBLIC_KEY=

# Sentry DSN for client error monitoring (production only).
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Google Analytics 4 measurement ID (production only).
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
